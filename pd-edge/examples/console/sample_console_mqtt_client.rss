// Run with:
// cargo run -p pd-edge --bin pd-edge-console --features mqtt -- --program pd-edge/examples/console/sample_console_mqtt_client.rss --run -- 127.0.0.1 mqtt demo/topic hello "" 0
//
// Args:
// - host
// - [scheme=mqtt|mqtts]
// - [topic]
// - [payload]
// - [subscribe-filter]
// - [qos=0|1]
//
// If subscribe-filter is non-empty, the sample waits for one MQTT event and prints it.

use console;
use mqtt;
use runtime;

let argc = console::args::count();

if argc == 0 {
    console::stderr::write("usage: <host> [scheme=mqtt|mqtts] [topic] [payload] [subscribe-filter] [qos=0|1]\n");
    console::stderr::write("example: 127.0.0.1 mqtt demo/topic hello \"\" 0\n");
    console::stderr::flush();
    runtime::exit();
} else {
    let host = console::args::get(0);
    if host == "" {
        console::stderr::write("host is required\n");
        console::stderr::flush();
        runtime::exit();
    }

    let scheme = if argc > 1 => {
        console::args::get(1)
    } else => {
        "mqtt"
    };
    let port = if scheme == "mqtts" => {
        8883
    } else => {
        1883
    };
    let topic = if argc > 2 => {
        console::args::get(2)
    } else => {
        ""
    };
    let payload = if argc > 3 => {
        console::args::get(3)
    } else => {
        ""
    };
    let subscribe_filter = if argc > 4 => {
        console::args::get(4)
    } else => {
        ""
    };
    let qos = if argc > 5 && console::args::get(5) == "1" => {
        1
    } else => {
        0
    };

    let connection = mqtt::connection::new();
    mqtt::connection::set_scheme(connection, scheme);
    mqtt::connection::set_target(connection, host, port);
    mqtt::connection::set_client_id(connection, "pd-edge-console-mqtt-sample");
    mqtt::connection::set_keep_alive_secs(connection, 30);
    mqtt::connection::set_clean_start(connection, true);

    console::stdout::write("phase-before-connect=" + mqtt::connection::get_phase(connection) + "\n");
    mqtt::connection::connect(connection);
    console::stdout::write("phase-after-connect=" + mqtt::connection::get_phase(connection) + "\n");

    if subscribe_filter != "" {
        mqtt::connection::subscribe(connection, subscribe_filter, qos);
        console::stdout::write("subscribed=" + subscribe_filter + "\n");
    }

    if topic != "" {
        mqtt::connection::publish_text(connection, topic, payload, qos, false);
        console::stdout::write("published-topic=" + topic + "\n");
    }

    if subscribe_filter != "" {
        let event = mqtt::connection::read_event(connection);
        if (&event).has("kind") {
            console::stdout::write("event-kind=" + (&event)["kind"] + "\n");
        }
        if (&event).has("topic") {
            console::stdout::write("event-topic=" + (&event)["topic"] + "\n");
        }
        if (&event).has("payload_text") {
            console::stdout::write((&event)["payload_text"] + "\n");
        }
        if (&event).has("reason") {
            console::stdout::write("event-reason=" + (&event)["reason"] + "\n");
        }
    }

    mqtt::connection::disconnect(connection, 0, "sample-complete");
    console::stdout::write("phase-after-disconnect=" + mqtt::connection::get_phase(connection) + "\n");
    console::stdout::flush();
}
