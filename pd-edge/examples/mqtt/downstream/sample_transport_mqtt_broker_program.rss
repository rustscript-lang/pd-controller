use runtime;
use tcp;
use tls;
use websocket;

// Run this under pd-edge-transport-proxy.
//
// One listener supports four carriage forms:
// - mqtt://   raw MQTT over downstream TCP
// - mqtts://  raw MQTT over downstream TLS
// - ws://     MQTT packets inside downstream WebSocket binary frames
// - wss://    MQTT packets inside downstream TLS + WebSocket binary frames
//
// Scope:
// - single-session echo broker
// - CONNECT / CONNACK
// - SUBSCRIBE / SUBACK
// - UNSUBSCRIBE / UNSUBACK
// - PUBLISH QoS 0 and 1
// - PUBACK
// - PINGREQ / PINGRESP
// - DISCONNECT
//
// The broker stores subscription filters for the active session and echoes
// matching publishes back to that same session as QoS 0 deliveries.

fn append_values(left, right) {
    let mut out = [];
    let mut index = 0;
    while index < left.length {
        out[out.length] = left[index];
        index = index + 1;
    }
    index = 0;
    while index < right.length {
        out[out.length] = right[index];
        index = index + 1;
    }
    out
}

fn take_values(source, start, count) {
    let mut out = [];
    let mut index = 0;
    while index < count && (start + index) < source.length {
        out[out.length] = source[start + index];
        index = index + 1;
    }
    out
}

fn low_7_bits(value) {
    value % 128
}

fn has_high_bit(value) {
    value >= 128
}

fn high_byte(value) {
    (value / 256) % 256
}

fn low_byte(value) {
    value % 256
}

fn u16_from_bytes(bytes, offset) {
    (bytes[offset] * 256) + bytes[offset + 1]
}

fn mqtt_qos_from_header(header) {
    (header / 2) % 4
}

fn mqtt_kind_from_header(header) {
    header / 16
}

fn exact_read_tcp(stream, want) {
    let mut out = [];
    while out.length < want {
        let chunk = tcp::stream::read_binary(stream, want - out.length);
        if chunk.length == 0 {
            break;
        }
        out = append_values(out, chunk);
    }
    out
}

fn read_mqtt_packet_tcp(stream) {
    let header = exact_read_tcp(stream, 1);
    if header.length != 1 => {
        []
    } else => {
        let mut len_bytes = [];
        let mut remaining = 0;
        let mut multiplier = 1;
        let mut complete = false;

        while len_bytes.length < 4 && !complete {
            let next = exact_read_tcp(stream, 1);
            if next.length != 1 {
                len_bytes = [];
                break;
            }
            let byte = next[0];
            len_bytes[len_bytes.length] = byte;
            remaining = remaining + (low_7_bits(byte) * multiplier);
            if !has_high_bit(byte) {
                complete = true;
            } else {
                multiplier = multiplier * 128;
            }
        }

        if !complete => {
            []
        } else => {
            let body = exact_read_tcp(stream, remaining);
            if body.length != remaining => {
                []
            } else => {
                append_values(append_values(header, len_bytes), body)
            };
        };
    }
}

fn encode_varint(value) {
    let mut remaining = value;
    let mut encoded = [];
    let mut done = false;
    while !done {
        let mut byte = remaining % 128;
        remaining = remaining / 128;
        if remaining > 0 {
            byte = byte + 128;
        } else {
            done = true;
        }
        encoded[encoded.length] = byte;
    }
    encoded
}

fn decode_varint(bytes, start) {
    let mut value = 0;
    let mut multiplier = 1;
    let mut index = start;
    let mut complete = 0;

    while index < bytes.length && index < (start + 4) {
        let byte = bytes[index];
        value = value + (low_7_bits(byte) * multiplier);
        index = index + 1;
        if !has_high_bit(byte) {
            complete = 1;
            break;
        }
        multiplier = multiplier * 128;
    }

    [value, index, complete]
}

fn packet_body(packet) {
    let info = decode_varint(packet, 1);
    if info[2] == 0 => {
        []
    } else => {
        let body_start = info[1];
        take_values(packet, body_start, packet.length - body_start)
    }
}

fn decode_utf8_field_bytes(bytes, offset) {
    if offset + 2 > bytes.length => {
        [[], -1]
    } else => {
        let len = u16_from_bytes(bytes, offset);
        let start = offset + 2;
        if start + len > bytes.length => {
            [[], -1]
        } else => {
            [take_values(bytes, start, len), start + len]
        };
    }
}

fn encode_utf8_field_bytes(bytes) {
    append_values([high_byte(bytes.length), low_byte(bytes.length)], bytes)
}

fn bytes_equal(left, right) {
    if left.length != right.length => {
        false
    } else => {
        let mut index = 0;
        let mut same = true;
        while index < left.length {
            if left[index] != right[index] {
                same = false;
                break;
            }
            index = index + 1;
        }
        same
    }
}

fn parse_subscribe(packet) {
    let body = packet_body(packet);
    if body.length < 3 => {
        [-1, [], []]
    } else => {
        let packet_id = u16_from_bytes(body, 0);
        let props = decode_varint(body, 2);
        let prop_len = props[0];
        let mut cursor = props[1] + prop_len;
        let mut filters = [];
        let mut qoses = [];
        let mut valid = props[2] == 1 && cursor <= body.length;

        while valid && cursor < body.length {
            let field = decode_utf8_field_bytes(body, cursor);
            let filter = field[0];
            cursor = field[1];
            if cursor < 0 || cursor >= body.length {
                valid = false;
                break;
            }
            filters[filters.length] = filter;
            qoses[qoses.length] = body[cursor] % 4;
            cursor = cursor + 1;
        }

        if !valid || filters.length == 0 => {
            [-1, [], []]
        } else => {
            [packet_id, filters, qoses]
        };
    }
}

fn parse_unsubscribe(packet) {
    let body = packet_body(packet);
    if body.length < 3 => {
        [-1, []]
    } else => {
        let packet_id = u16_from_bytes(body, 0);
        let props = decode_varint(body, 2);
        let prop_len = props[0];
        let mut cursor = props[1] + prop_len;
        let mut filters = [];
        let mut valid = props[2] == 1 && cursor <= body.length;

        while valid && cursor < body.length {
            let field = decode_utf8_field_bytes(body, cursor);
            let filter = field[0];
            cursor = field[1];
            if cursor < 0 {
                valid = false;
                break;
            }
            filters[filters.length] = filter;
        }

        if !valid || filters.length == 0 => {
            [-1, []]
        } else => {
            [packet_id, filters]
        };
    }
}

fn parse_publish(packet) {
    if packet.length == 0 => {
        [[], [], -1, -1]
    } else => {
        let header = packet[0];
        let qos = mqtt_qos_from_header(header);
        let body = packet_body(packet);
        let topic_field = decode_utf8_field_bytes(body, 0);
        let topic = topic_field[0];
        let mut cursor = topic_field[1];
        let mut packet_id = -1;

        if cursor < 0 => {
            [[], [], -1, -1]
        } else => {
            if qos > 0 {
                if cursor + 2 > body.length {
                    cursor = -1;
                } else {
                    packet_id = u16_from_bytes(body, cursor);
                    cursor = cursor + 2;
                }
            }

            if cursor < 0 => {
                [[], [], -1, -1]
            } else => {
                let props = decode_varint(body, cursor);
                if props[2] == 0 => {
                    [[], [], -1, -1]
                } else => {
                    cursor = props[1] + props[0];
                    if cursor > body.length => {
                        [[], [], -1, -1]
                    } else => {
                        [topic, take_values(body, cursor, body.length - cursor), qos, packet_id]
                    };
                };
            };
        };
    }
}

fn build_suback(packet_id, qoses) {
    let mut body = [high_byte(packet_id), low_byte(packet_id), 0];
    body = append_values(body, qoses);
    let mut packet = [144];
    packet = append_values(packet, encode_varint(body.length));
    append_values(packet, body)
}

fn build_unsuback(packet_id, filter_count) {
    let mut reasons = [];
    let mut index = 0;
    while index < filter_count {
        reasons[reasons.length] = 0;
        index = index + 1;
    }
    let mut body = [high_byte(packet_id), low_byte(packet_id), 0];
    body = append_values(body, reasons);
    let mut packet = [176];
    packet = append_values(packet, encode_varint(body.length));
    append_values(packet, body)
}

fn build_puback(packet_id) {
    [64, 4, high_byte(packet_id), low_byte(packet_id), 0, 0]
}

fn build_publish(topic, payload) {
    let mut body = encode_utf8_field_bytes(topic);
    body = append_values(body, [0]);
    body = append_values(body, payload);
    let mut packet = [48];
    packet = append_values(packet, encode_varint(body.length));
    append_values(packet, body)
}

fn topic_matches(filter, topic) {
    let mut filter_index = 0;
    let mut topic_index = 0;
    let mut matched = true;
    let mut done = false;

    while filter_index < filter.length && !done {
        let byte = filter[filter_index];

        if byte == 35 {
            matched = filter_index == filter.length - 1;
            done = true;
        } else if byte == 43 {
            while topic_index < topic.length && topic[topic_index] != 47 {
                topic_index = topic_index + 1;
            }
            filter_index = filter_index + 1;
            if filter_index == filter.length {
                matched = topic_index == topic.length;
                done = true;
            } else if filter[filter_index] != 47 {
                matched = false;
                done = true;
            } else if topic_index >= topic.length || topic[topic_index] != 47 {
                matched = false;
                done = true;
            } else {
                filter_index = filter_index + 1;
                topic_index = topic_index + 1;
            }
        } else {
            if topic_index >= topic.length || topic[topic_index] != byte {
                matched = false;
                done = true;
            } else {
                filter_index = filter_index + 1;
                topic_index = topic_index + 1;
            }
        }
    }

    matched && topic_index == topic.length
}

fn any_subscription_matches(subscriptions, topic) {
    let mut index = 0;
    let mut matched = false;
    while index < subscriptions.length {
        if topic_matches(subscriptions[index], topic) {
            matched = true;
            break;
        }
        index = index + 1;
    }
    matched
}

fn remove_subscriptions(subscriptions, removals) {
    let mut kept = [];
    let mut outer = 0;
    while outer < subscriptions.length {
        let mut remove = false;
        let mut inner = 0;
        while inner < removals.length {
            if bytes_equal(subscriptions[outer], removals[inner]) {
                remove = true;
                break;
            }
            inner = inner + 1;
        }
        if !remove {
            kept[kept.length] = subscriptions[outer];
        }
        outer = outer + 1;
    }
    kept
}

fn handle_mqtt_packet(packet, subscriptions) {
    let mut next_subscriptions = subscriptions;
    let mut responses = [];
    let mut close = 0;

    if packet.length == 0 {
        close = 1;
    } else {
        let kind = mqtt_kind_from_header(packet[0]);

        if kind == 1 {
            responses[responses.length] = [32, 3, 0, 0, 0];
        } else if kind == 8 {
            let parsed = parse_subscribe(packet);
            let packet_id = parsed[0];
            let filters = parsed[1];
            let qoses = parsed[2];
            if packet_id < 0 {
                close = 1;
            } else {
                let mut index = 0;
                while index < filters.length {
                    next_subscriptions[next_subscriptions.length] = filters[index];
                    index = index + 1;
                }
                responses[responses.length] = build_suback(packet_id, qoses);
            }
        } else if kind == 10 {
            let parsed = parse_unsubscribe(packet);
            let packet_id = parsed[0];
            let filters = parsed[1];
            if packet_id < 0 {
                close = 1;
            } else {
                next_subscriptions = remove_subscriptions(next_subscriptions, filters);
                responses[responses.length] = build_unsuback(packet_id, filters.length);
            }
        } else if kind == 3 {
            let parsed = parse_publish(packet);
            let topic = parsed[0];
            let payload = parsed[1];
            let qos = parsed[2];
            let packet_id = parsed[3];
            if qos < 0 || qos > 1 {
                close = 1;
            } else {
                if qos == 1 && packet_id >= 0 {
                    responses[responses.length] = build_puback(packet_id);
                }
                if any_subscription_matches(next_subscriptions, topic) {
                    responses[responses.length] = build_publish(topic, payload);
                }
            }
        } else if kind == 12 {
            responses[responses.length] = [208, 0];
        } else if kind == 14 {
            close = 1;
        } else {
            close = 1;
        }
    }

    [next_subscriptions, responses, close]
}

fn broker_tcp(downstream) {
    let mut subscriptions = [];

    while !tcp::stream::eof(downstream) {
        let packet = read_mqtt_packet_tcp(downstream);
        if packet.length == 0 {
            break;
        }

        let action = handle_mqtt_packet(packet, subscriptions);
        subscriptions = action[0];
        let responses = action[1];
        let mut index = 0;
        while index < responses.length {
            tcp::stream::write_binary(downstream, responses[index]);
            index = index + 1;
        }
        if action[2] != 0 {
            break;
        }
    }

    tcp::stream::close(downstream);
    0
}

fn broker_websocket(connection) {
    let mut subscriptions = [];

    while !websocket::connection::eof(connection) {
        let packet = websocket::connection::read_binary(connection);
        if packet.length == 0 {
            break;
        }

        let action = handle_mqtt_packet(packet, subscriptions);
        subscriptions = action[0];
        let responses = action[1];
        let mut index = 0;
        while index < responses.length {
            websocket::connection::send_binary(connection, responses[index]);
            index = index + 1;
        }
        if action[2] != 0 {
            break;
        }
    }

    if !websocket::connection::eof(connection) {
        websocket::connection::close(connection, 1000, "mqtt-broker-complete");
    }
    0
}

fn looks_like_tls_client_hello(prefix) {
    prefix.length >= 3 && prefix[0] == 22 && prefix[1] == 3
}

fn looks_like_http_get(prefix) {
    prefix.length >= 4 &&
        prefix[0] == 71 &&
        prefix[1] == 69 &&
        prefix[2] == 84 &&
        prefix[3] == 32
}

let downstream = tcp::stream::downstream();
let initial_prefix = tcp::stream::peek_binary(downstream, 3);

if looks_like_tls_client_hello(initial_prefix) {
    let session = tls::session::from_socket(downstream);
    if !tls::session::handshake(session) {
        tcp::stream::close(downstream);
        runtime::exit();
    }
}

let plaintext_prefix = tcp::stream::peek_binary(downstream, 4);
if looks_like_http_get(plaintext_prefix) {
    let connection = websocket::connection::downstream();
    websocket::connection::set_subprotocols(connection, "mqtt");
    websocket::connection::connect(connection);
    broker_websocket(connection);
} else {
    broker_tcp(downstream);
}
