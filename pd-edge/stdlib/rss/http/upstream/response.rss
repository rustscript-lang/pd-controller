// Convenience wrappers over the default outbound HTTP exchange response.
use http;
use io;

fn upstream_response_default_exchange() -> int {
    http::exchange::default_upstream()
}

pub fn get_status() -> int {
    http::exchange::get_status(upstream_response_default_exchange())
}

pub fn get_header(name: string) -> string {
    http::exchange::get_header(upstream_response_default_exchange(), name)
}

pub fn get_headers() -> map<string> {
    http::exchange::get_headers(upstream_response_default_exchange())
}

pub fn get_body() -> string {
    http::exchange::get_body(upstream_response_default_exchange())
}

pub fn get_http_version() -> string {
    http::exchange::get_http_version(upstream_response_default_exchange())
}

pub fn next_chunk(max_bytes: int) -> string {
    http::exchange::body::next_chunk(upstream_response_default_exchange(), max_bytes)
}

pub fn next_line() -> string {
    io::read_line(upstream_response_default_exchange())
}

pub fn eof() -> bool {
    http::exchange::body::eof(upstream_response_default_exchange())
}

pub fn read_all() -> string {
    io::read_all(upstream_response_default_exchange())
}

pub fn read_line() -> string {
    io::read_line(upstream_response_default_exchange())
}
