// Collection helpers implemented in pure RustScript.

// Returns the first index of a value in an array, or -1 when it is absent.
pub fn index_of<T>(values: [T], needle: T) -> int {
    let mut found =-1;
    for (let mut find_index = 0; find_index < values.length; find_index = find_index + 1) {
        if values[find_index] == needle {
            found = find_index;
            break;
        }
    }
    found
}

// Returns whether an array contains a value.
pub fn contains<T>(values: [T], needle: T) -> bool {
    index_of::<T>(values, needle) >-1
}

// Returns a reversed copy of an array.
pub fn reverse<T>(values: [T]) -> [T] {
    let mut out: [T] = [];
    for (
        let mut reverse_index = values.length - 1;
        reverse_index >-1;
        reverse_index = reverse_index - 1
    ) {
        out[out.length] = values[reverse_index];
    }
    out
}

// Returns an array with duplicate values removed.
pub fn dedup<T>(values: [T]) -> [T] {
    let mut out: [T] = [];
    for (let mut dedup_index = 0; dedup_index < values.length; dedup_index = dedup_index + 1) {
        let value = values[dedup_index];
        if contains::<T>(out, value) == false {
            out[out.length] = value;
        }
    }
    out
}

// Returns whether a map contains a key.
pub fn has<K, V>(map: map<V>, key: K) -> bool {
    map.has(key)
}

// Returns a map value or a fallback when the key is absent.
pub fn get_or<K, V>(map: map<V>, key: K, fallback: V) -> V {
    let mut out: V = fallback;
    if has::<K, V>(map, key) {
        out = map[key];
    }
    out
}

// Returns the values from a map as an array.
pub fn values<V>(map: map<V>) -> [V] {
    let keys =(&map).keys;
    let mut out: [V] = [];
    for (let mut value_index = 0; value_index <(&keys).length; value_index = value_index + 1) {
        out[out.length] = map[(&keys)[value_index]];
    }
    out
}

// Returns the [key, value] pairs from a map as an array.
pub fn entries<K, V>(map: map<V>) -> [[K, V]] {
    let keys =(&map).keys;
    let mut out: [[K, V]] = [];
    for (let mut entry_index = 0; entry_index <(&keys).length; entry_index = entry_index + 1) {
        out[out.length] = [(&keys)[entry_index], map[(&keys)[entry_index]]];
    }
    out
}

// Merges two maps, preferring values from rhs for duplicate keys.
pub fn merge<V>(lhs: map<V>, rhs: map<V>) -> map<V> {
    let mut out: map<V> = {};

    let lhs_keys =(&lhs).keys;
    for (let mut left_index = 0; left_index <(&lhs_keys).length; left_index = left_index + 1) {
        out[(&lhs_keys)[left_index]] = lhs[(&lhs_keys)[left_index]];
    }

    let rhs_keys =(&rhs).keys;
    for (let mut right_index = 0; right_index <(&rhs_keys).length; right_index = right_index + 1) {
        out[(&rhs_keys)[right_index]] = rhs[(&rhs_keys)[right_index]];
    }
    out
}

